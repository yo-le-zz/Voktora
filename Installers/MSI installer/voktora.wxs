<?xml version="1.0" encoding="UTF-8"?>
<!--
  Voktora — voktora.wxs
  Définition WiX Toolset pour la création du .msi Windows

  Génération :
    wix build voktora.wxs -o dist\windows\Voktora_1.0.0_x64.msi
  ou avec les anciens outils WiX 3.x :
    candle.exe voktora.wxs -out voktora.wixobj
    light.exe voktora.wixobj -out Voktora_1.0.0_x64.msi -ext WixUIExtension
-->
<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs"
     xmlns:ui="http://wixtoolset.org/schemas/v4/wxs/ui">

  <Package Name="Voktora"
           Manufacturer="yolezz"
           Version="$(var.VERSION)"
           Language="1036"
           Codepage="1252"
           UpgradeCode="4A8B3C1D-E5F6-7890-ABCD-EF1234567890"
           InstallerVersion="500"
           Compressed="yes"
           Scope="perMachine">

    <SummaryInformation Keywords="Voktora Project Manager"
                        Description="Voktora — Project Instance Manager by yolezz"
                        Manufacturer="yolezz"/>

    <!-- Icône (doit pointer vers dist\windows\voktora.dist\assets\Voktora.ico) -->
    <Icon Id="VoktoraIcon" SourceFile="dist\windows\voktora.dist\assets\Voktora.ico"/>
    <Property Id="ARPPRODUCTICON" Value="VoktoraIcon"/>
    <Property Id="ARPHELPLINK" Value="https://github.com/yo-le-zz/Voktora"/>
    <Property Id="ARPURLINFOABOUT" Value="https://github.com/yo-le-zz/Voktora"/>
    <Property Id="ARPNOREPAIR" Value="1"/>

    <!-- Dossier d'installation : C:\Program Files\Voktora\ -->
    <StandardDirectory Id="ProgramFiles64Folder">
      <Directory Id="VOKTORA_DIR" Name="Voktora">
        <Component Id="MainExecutable" Guid="1B2C3D4E-5F6A-7B8C-9D0E-1F2A3B4C5D6E">
          <File Id="VoktoraExe"
                Source="dist\windows\voktora.dist\voktora.exe"
                Name="Voktora.exe"
                KeyPath="yes"/>
          <!-- Raccourci Bureau -->
          <Shortcut Id="DesktopShortcut"
                    Directory="DesktopFolder"
                    Name="Voktora"
                    Description="Project Instance Manager"
                    Icon="VoktoraIcon"
                    WorkingDirectory="VOKTORA_DIR"/>
          <!-- Raccourci Menu Démarrer -->
          <Shortcut Id="StartMenuShortcut"
                    Directory="VoktoraStartMenu"
                    Name="Voktora"
                    Description="Project Instance Manager"
                    Icon="VoktoraIcon"
                    WorkingDirectory="VOKTORA_DIR"/>
        </Component>

        <!-- Toutes les DLLs / fichiers du onedir Nuitka -->
        <!-- Généré dynamiquement par build_msi.py via heat.exe ou wix harvest -->
        <?include voktora_files.wxs ?>
      </Directory>
    </StandardDirectory>

    <!-- Menu Démarrer -->
    <StandardDirectory Id="ProgramMenuFolder">
      <Directory Id="VoktoraStartMenu" Name="Voktora"/>
    </StandardDirectory>
    <StandardDirectory Id="DesktopFolder"/>

    <Feature Id="MainFeature" Title="Voktora" Level="1">
      <ComponentRef Id="MainExecutable"/>
      <ComponentGroupRef Id="VoktoraFiles"/>
    </Feature>

    <ui:WixUI Id="WixUI_InstallDir"/>
    <Property Id="WIXUI_INSTALLDIR" Value="VOKTORA_DIR"/>

    <!-- Désinstallation propre -->
    <Upgrade Id="4A8B3C1D-E5F6-7890-ABCD-EF1234567890">
      <UpgradeVersion Minimum="0.0.0" Maximum="$(var.VERSION)"
                      Property="OLDERVERSIONBEINGUPGRADED"
                      IncludeMaximum="no"/>
    </Upgrade>
    <InstallExecuteSequence>
      <RemoveExistingProducts After="InstallInitialize"/>
    </InstallExecuteSequence>

  </Package>
</Wix>
