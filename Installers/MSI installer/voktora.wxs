<?xml version="1.0" encoding="UTF-8"?>
<!--
  Voktora — voktora.wxs
  WiX Toolset 4.x

  Ce fichier est dans :  Voktora/Installers/MSI installer/voktora.wxs
  voktora_files.wxs est généré dans le même dossier par build_msi.py (pur Python).

  Variables passées par build_msi.py :
    VERSION   — ex. 1.0.0
    SourceDir — chemin absolu vers dist\windows\voktora.dist\

  Génération :
    python "Installers/MSI installer/build_msi.py" [VERSION]
-->
<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs"
     xmlns:ui="http://wixtoolset.org/schemas/v4/wxs/ui">

  <Package Name="Voktora"
           Manufacturer="yolezz"
           Version="$(var.VERSION)"
           Language="1036"
           Codepage="1252"
           UpgradeCode="4A8B3C1D-E5F6-7890-ABCD-EF1234567890"
           InstallerVersion="500"
           Compressed="yes"
           Scope="perMachine">

    <SummaryInformation Keywords="Voktora Project Manager"
                        Description="Voktora — Project Instance Manager by yolezz"
                        Manufacturer="yolezz"/>

    <Icon Id="VoktoraIcon" SourceFile="$(var.SourceDir)\assets\Voktora.ico"/>
    <Property Id="ARPPRODUCTICON"  Value="VoktoraIcon"/>
    <Property Id="ARPHELPLINK"     Value="https://github.com/yo-le-zz/Voktora"/>
    <Property Id="ARPURLINFOABOUT" Value="https://github.com/yo-le-zz/Voktora"/>
    <Property Id="ARPNOREPAIR"     Value="1"/>

    <!-- Dossier d'installation : C:\Program Files\Voktora\ -->
    <StandardDirectory Id="ProgramFiles64Folder">
      <Directory Id="VOKTORA_DIR" Name="Voktora">

        <!-- Exécutable principal + raccourcis -->
        <Component Id="MainExecutable" Guid="1B2C3D4E-5F6A-7B8C-9D0E-1F2A3B4C5D6E">
          <File Id="VoktoraExe"
                Source="$(var.SourceDir)\voktora.exe"
                Name="Voktora.exe"
                KeyPath="yes"/>
          <Shortcut Id="DesktopShortcut"
                    Directory="DesktopFolder"
                    Name="Voktora"
                    Description="Project Instance Manager"
                    Icon="VoktoraIcon"
                    WorkingDirectory="VOKTORA_DIR"/>
          <Shortcut Id="StartMenuShortcut"
                    Directory="VoktoraStartMenu"
                    Name="Voktora"
                    Description="Project Instance Manager"
                    Icon="VoktoraIcon"
                    WorkingDirectory="VOKTORA_DIR"/>
        </Component>

        <!--
          Tous les fichiers du onedir Nuitka (DLLs, Qt plugins, themes, assets…).
          voktora_files.wxs est généré par build_msi.py via os.walk — sans
          dépendance à wix harvest ni heat.exe.
          voktora.exe est exclu du fichier généré (déjà déclaré ci-dessus).
        -->
        <?include voktora_files.wxs ?>

      </Directory>
    </StandardDirectory>

    <!-- Menu Démarrer -->
    <StandardDirectory Id="ProgramMenuFolder">
      <Directory Id="VoktoraStartMenu" Name="Voktora"/>
    </StandardDirectory>
    <StandardDirectory Id="DesktopFolder"/>

    <Feature Id="MainFeature" Title="Voktora" Level="1">
      <ComponentRef Id="MainExecutable"/>
      <ComponentGroupRef Id="VoktoraFiles"/>
    </Feature>

    <ui:WixUI Id="WixUI_InstallDir"/>
    <Property Id="WIXUI_INSTALLDIR" Value="VOKTORA_DIR"/>

    <!-- Upgrade propre : supprime l'ancienne version avant installation -->
    <Upgrade Id="4A8B3C1D-E5F6-7890-ABCD-EF1234567890">
      <UpgradeVersion Minimum="0.0.0" Maximum="$(var.VERSION)"
                      Property="OLDERVERSIONBEINGUPGRADED"
                      IncludeMaximum="no"/>
    </Upgrade>
    <InstallExecuteSequence>
      <RemoveExistingProducts After="InstallInitialize"/>
    </InstallExecuteSequence>

  </Package>
</Wix>